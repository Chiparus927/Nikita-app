    // ── Async role loading ────────────────────────────────────────────────────
    private async Task LoadRolesAsync()
    {
        try
        {
            var table = await Task.Run(() => new UtilizatoriRepository().GetPublicRoluriTable());
            _rol.Items.Clear();
            _rol.DataSource    = table;
            _rol.DisplayMember = "nume";
            _rol.ValueMember   = "id";
            _rol.Enabled       = true;
            var defaultId = table.Rows.Count > 0 ? Convert.ToInt32(table.Rows[0]["id"]) : 0;
            if (defaultId > 0) _rol.SelectedValue = defaultId;
            else if (_rol.Items.Count > 0) _rol.SelectedIndex = 0;
        }
        catch (Exception ex) { ShowError("Roluri indisponibile: " + ex.Message); }
    }

