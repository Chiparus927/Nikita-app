        public BufferedPanel() { DoubleBuffered = true; SetStyle(ControlStyles.AllPaintingInWmPaint | ControlStyles.OptimizedDoubleBuffer | ControlStyles.ResizeRedraw, true); }
    }

    private sealed class PasswordStrengthBar : Control
    {
        private readonly System.Windows.Forms.Timer _timer = new() { Interval = 12 };
        private float _progress;
        private float _targetProgress;
        private Color _fillColor = Color.FromArgb(190, 190, 190);

        public PasswordStrengthBar()
        {
            DoubleBuffered = true; BackColor = Color.White;
            _timer.Tick += (_, _) =>
            {
                _progress += (_targetProgress - _progress) * 0.22f;
                if (Math.Abs(_targetProgress - _progress) < 0.01f) { _progress = _targetProgress; _timer.Stop(); }
                Invalidate();
            };
        }
        public float TargetProgress { get => _targetProgress; set { _targetProgress = Math.Clamp(value, 0f, 1f); _timer.Start(); } }
        public Color FillColor      { get => _fillColor;      set { _fillColor = value; Invalidate(); } }

        protected override void OnPaint(PaintEventArgs e)
        {
            base.OnPaint(e);
            AppTheme.ApplyHighQualityGraphics(e.Graphics);
            var rect = new Rectangle(0, 0, Width - 1, Height - 1);
            using var trackPath = AppTheme.RoundedPath(rect, Height / 2);
            e.Graphics.FillPath(new SolidBrush(Color.FromArgb(225, 225, 225)), trackPath);
            var fillWidth = (int)Math.Round((Width - 1) * _progress);
            if (fillWidth <= 0) return;
            var fillRect = new Rectangle(0, 0, Math.Max(Height, fillWidth), Height - 1);
            using var fillPath = AppTheme.RoundedPath(fillRect, Height / 2);
            e.Graphics.FillPath(new SolidBrush(_fillColor), fillPath);
        }
    }

    private static readonly Image HeroImage = LoadHeroImage();
    private static Image LoadHeroImage()
    {
        try
        {
            var path = Path.Combine(AppContext.BaseDirectory, "Assets", "4 Ways to Improve Construction Site Safety.jpeg");
            if (File.Exists(path)) return new Bitmap(path);
        }
        catch { }
        var bmp = new Bitmap(1200, 900);
        using var g = Graphics.FromImage(bmp);
        AppTheme.ApplyHighQualityGraphics(g);
        using var gradient = new System.Drawing.Drawing2D.LinearGradientBrush(new Rectangle(0, 0, bmp.Width, bmp.Height), Color.FromArgb(20, 28, 44), Color.FromArgb(8, 12, 22), 45f);
        g.FillRectangle(gradient, 0, 0, bmp.Width, bmp.Height);
        using var accent = new SolidBrush(Color.FromArgb(90, AppTheme.Accent));
        g.FillRectangle(accent, 220, 180, 760, 420);
        return bmp;
    }

    private sealed class RegisterHeroPanel : Panel
    {
        public RegisterHeroPanel() { DoubleBuffered = true; ResizeRedraw = true; SetStyle(ControlStyles.UserPaint | ControlStyles.AllPaintingInWmPaint | ControlStyles.OptimizedDoubleBuffer | ControlStyles.ResizeRedraw, true); }
        protected override void OnPaint(PaintEventArgs e)
        {
            base.OnPaint(e);
            AppTheme.ApplyHighQualityGraphics(e.Graphics);
            if (HeroImage != null) AppTheme.DrawImageCover(e.Graphics, HeroImage, ClientRectangle);
            else e.Graphics.Clear(Color.FromArgb(14, 18, 26));
            using var overlay = new SolidBrush(Color.FromArgb(70, 0, 0, 0));
            e.Graphics.FillRectangle(overlay, ClientRectangle);
        }
    }
