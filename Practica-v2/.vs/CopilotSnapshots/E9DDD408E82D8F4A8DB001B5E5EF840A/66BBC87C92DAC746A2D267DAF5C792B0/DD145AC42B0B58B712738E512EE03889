    private static bool IsValidEmail(string email)
    {
        var trimmed = email.Trim();
        try
        {
            var addr   = new MailAddress(trimmed);
            if (!string.Equals(addr.Address, trimmed, StringComparison.OrdinalIgnoreCase)) return false;
            var allowed = new HashSet<string> { "gmail.com","yahoo.com","outlook.com","hotmail.com","icloud.com","mail.ru","yandex.com","proton.me","protonmail.com" };
            return allowed.Contains(addr.Host.ToLowerInvariant());
        }
        catch { return false; }
    }

    // ── Password strength ─────────────────────────────────────────────────────
    private void UpdatePasswordStrength()
    {
        var score = 0;
        if (_parola.Text.Length >= 8)                           score++;
        if (_parola.Text.Any(char.IsUpper))                     score++;
        if (_parola.Text.Any(ch => !char.IsLetterOrDigit(ch)))  score++;
        _passwordStrengthBar.TargetProgress = score / 3f;
        _passwordStrengthBar.FillColor = score switch { 0 => Color.FromArgb(190,190,190), 1 => Color.FromArgb(239,68,68), 2 => Color.FromArgb(245,158,11), _ => AppTheme.Success };
        _passwordHint.ForeColor = score == 3 ? AppTheme.Success : Color.FromArgb(110, 118, 136);
    }

