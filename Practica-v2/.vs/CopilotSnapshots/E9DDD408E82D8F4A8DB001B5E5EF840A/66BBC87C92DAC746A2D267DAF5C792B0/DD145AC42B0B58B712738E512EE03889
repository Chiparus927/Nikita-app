        var p = new Panel { Size = new Size(width, 48), Location = new Point(x, y), BackColor = Color.White, Padding = new Padding(10, 13, 10, 8), BorderStyle = BorderStyle.FixedSingle, Tag = lbl };
        tb.Dock = DockStyle.Fill;
        p.Controls.Add(tb);
        parent.Controls.Add(p);
        return p;
    }

    private static Label AddCombo(Control parent, string label, ComboBox combo, int x, int y, int width)
