    // ── Registration logic ────────────────────────────────────────────────────
    private void Register()
    {
        if (string.IsNullOrWhiteSpace(_nume.Text) || string.IsNullOrWhiteSpace(_prenume.Text) ||
            string.IsNullOrWhiteSpace(_email.Text) || string.IsNullOrWhiteSpace(_parola.Text))
        {
            ShowError("Completeaza campurile obligatorii.");
            if (string.IsNullOrWhiteSpace(_nume.Text))    AppTheme.MarkInvalid(_numeBox);
            if (string.IsNullOrWhiteSpace(_prenume.Text)) AppTheme.MarkInvalid(_prenumeBox);
            if (string.IsNullOrWhiteSpace(_email.Text))   AppTheme.MarkInvalid(_emailBox);
            if (string.IsNullOrWhiteSpace(_parola.Text))  AppTheme.MarkInvalid(_parolaBox);
            return;
        }

        if (_cmbTipEntitate.SelectedIndex == 1 && string.IsNullOrWhiteSpace(_companie.Text))
        {
            ShowError("Introduceți numele companiei pentru Persoană Juridică.");
            AppTheme.MarkInvalid(_companieBox);
            return;
        }
        if (!IsValidEmail(_email.Text)) { ShowError("Email invalid. Foloseste un email real, ex: nume@gmail.com."); AppTheme.MarkInvalid(_emailBox); return; }
        if (!IsValidPhone(_telefon.Text)) { ShowError("Telefonul trebuie sa fie in format +373 urmat de 8 cifre."); AppTheme.MarkInvalid(_telefonBox); return; }
        if (!IsStrongPassword(_parola.Text)) { ShowError("Parola trebuie sa aiba minim 8 caractere, o litera mare si un caracter special."); AppTheme.MarkInvalid(_parolaBox); return; }
        if (_parola.Text != _confirma.Text) { ShowError("Parolele nu coincid."); AppTheme.MarkInvalid(_parolaBox); AppTheme.MarkInvalid(_confirmaBox); return; }
        if (_rol.SelectedValue == null) { ShowError("Alege un rol."); AppTheme.MarkInvalid(_rol); return; }

        var repo = new UtilizatoriRepository();
        if (repo.ExistsByEmail(_email.Text)) { ShowError("Email deja folosit."); AppTheme.MarkInvalid(_emailBox); return; }
        if (repo.ExistsByTelefon(_telefon.Text.Trim())) { ShowError("Telefon deja folosit."); AppTheme.MarkInvalid(_telefonBox); return; }

        try
        {
            var user = new Models.Utilizator
            {
                Nume         = _nume.Text.Trim(),
                Prenume      = _prenume.Text.Trim(),
                Email        = _email.Text.Trim(),
                Telefon      = _telefon.Text.Trim(),
                IdRol        = Convert.ToInt32(_rol.SelectedValue),
                Activ        = true,
                IsApproved   = false,
                NumeCompanie = _cmbTipEntitate.SelectedIndex == 1 ? _companie.Text.Trim() : string.Empty
            };
            repo.RegisterPublic(user, PasswordHelper.Hash(_parola.Text));
            var isClient = repo.IsClientRole(user.IdRol);
            MessageBox.Show(
                isClient
                    ? "Cont de client creat cu succes. Te poti autentifica imediat."
                    : "Cont creat cu succes. Asteapta aprobarea unui administrator inainte de autentificare.",
                "VALCONGRUP", MessageBoxButtons.OK, MessageBoxIcon.Information);
            Close();
        }
        catch (UnauthorizedAccessException) { ShowError("Unauthorized: rolul Admin nu poate fi solicitat la inregistrare."); }
        catch (Exception ex) { ShowError("Eroare creare cont: " + ex.Message); }
    }

    // ── Validators ────────────────────────────────────────────────────────────
    private static bool IsValidPhone(string phone)     => Regex.IsMatch(phone.Trim(), @"^\+373\d{8}$");
    private static bool IsStrongPassword(string pwd)   => pwd.Length >= 8 && pwd.Any(char.IsUpper) && pwd.Any(ch => !char.IsLetterOrDigit(ch));

