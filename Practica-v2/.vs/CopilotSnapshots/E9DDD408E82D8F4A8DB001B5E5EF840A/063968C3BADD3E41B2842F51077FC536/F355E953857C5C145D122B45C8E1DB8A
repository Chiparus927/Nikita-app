html {
  font-size: 14px;
}

@media (min-width: 768px) {
  html {
    font-size: 16px;
  }
}

.btn:focus, .btn:active:focus, .btn-link.nav-link:focus, .form-control:focus, .form-check-input:focus {
  box-shadow: 0 0 0 0.1rem white, 0 0 0 0.25rem #258cfb;
}

html {
  position: relative;
  min-height: 100%;
}

body {
  margin-bottom: 60px;
}

/* Global typography */
:root { --brand-accent: #ff7a00; --card-radius: 10px; --card-shadow: 0 6px 18px rgba(12,18,28,0.06); }
body, button, input, select, textarea {
  font-family: system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* Primary button */
.vc-btn-primary {
  background: var(--brand-accent);
  color: #fff;
  border: none;
  border-radius: 6px;
  padding: 10px 18px;
  box-shadow: none;
}
.vc-btn-primary:hover { filter: brightness(0.95); }

/* Card visuals */
.vc-card { background: #fff; border-radius: var(--card-radius); box-shadow: var(--card-shadow); border: 1px solid rgba(0,0,0,0.04); }

/* Notification badge */
.vc-notification { position: relative; display: inline-block; }
.vc-notification .vc-badge { position: absolute; right: -6px; top: -6px; width: 12px; height: 12px; background: var(--brand-accent); border-radius: 50%; border: 2px solid #fff; }

/* Header search */
.vc-search { width: 360px; max-width: 50%; display: inline-flex; align-items: center; }
.vc-search input { width: 100%; padding: 8px 12px; border-radius: 6px; border: 1px solid #e6eefc; }

/* Empty state center */
.vc-empty { padding: 48px 12px; text-align: center; color: #6b7280; }

.form-floating > .form-control-plaintext::placeholder, .form-floating > .form-control::placeholder {
  color: var(--bs-secondary-color);
  text-align: end;
}

.form-floating > .form-control-plaintext:focus::placeholder, .form-floating > .form-control:focus::placeholder {
  text-align: start;
}